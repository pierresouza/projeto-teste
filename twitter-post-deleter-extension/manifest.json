{
  "manifest_version": 3,
  "name": "X Repost Deleter",
  "version": "1.0.0",
  "description": "Detecta login e apaga republicados (retweets) do X (Twitter) em segundo plano.",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.x.com/*",
    "https://*.twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir X Repost Deleter"
  }
}
