{
  "manifest_version": 3,
  "name": "Social Suite Manager",
  "version": "1.0.0",
  "description": "Suíte premium para gerenciamento de amizades e limpeza de posts no Instagram e X (Twitter).",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Social Suite Manager"
  }
}
